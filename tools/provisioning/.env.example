# Personal Access Token Supabase (creato da https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=

# Organization ID Supabase (presa da https://supabase.com/dashboard/org/<slug>/settings)
SUPABASE_ORG_ID=

# Region default per nuovi progetti
SUPABASE_REGION=eu-west-1

# Pricing tier default
SUPABASE_PLAN=pro

# Path supabase CLI (default: usa npx supabase)
SUPABASE_CLI=npx supabase

# Email/password default per gli utenti seed (NON committare valori reali)
SEED_USERS_PASSWORD=
