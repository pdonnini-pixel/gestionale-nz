# =============================================================================
# Frontend env vars — Gestionale NZ multi-tenant
# =============================================================================
#
# Ogni site Netlify (uno per tenant) ha SOLO le proprie env vars valorizzate.
# Per dev locale, valorizzare le NEWZAGO (default) oppure VITE_SUPABASE_URL/KEY.
#
# Le env del tenant attivo vengono selezionate a runtime da
# src/lib/tenants.ts in base al hostname (window.location.hostname).
# =============================================================================

# --- Tenant New Zago Srl (gestionale-nz.netlify.app, dev locale) -------------
VITE_SUPABASE_URL_NEWZAGO=https://xfvfxsvqpnpvibgeqpqp.supabase.co
VITE_SUPABASE_ANON_KEY_NEWZAGO=

# --- Tenant Made Retail Srl (made-gestionale-nz.netlify.app) -----------------
# Valori in output di tools/provisioning/full-provision.ts made-retail
VITE_SUPABASE_URL_MADE=
VITE_SUPABASE_ANON_KEY_MADE=

# --- Tenant Zago Srl (zago-gestionale-nz.netlify.app) ------------------------
# Valori in output di tools/provisioning/full-provision.ts zago
VITE_SUPABASE_URL_ZAGO=
VITE_SUPABASE_ANON_KEY_ZAGO=

# --- Fallback dev locale (se le NEWZAGO non sono valorizzate) ----------------
# Lasciate vuoti in produzione: src/lib/tenants.ts ha già un legacy fallback
# hardcoded sul progetto NZ per i dev che non vogliono valorizzare l'.env.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
